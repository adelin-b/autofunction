# autofunction wires Vercel AI SDK providers — auth uses whatever each
# provider's instantiation expects. For @ai-sdk/anthropic, the default
# `anthropic("...")` factory auto-reads ANTHROPIC_API_KEY from env.
ANTHROPIC_API_KEY=

# Built-in claudeP({ model }) adapter wraps the Claude Code CLI as a
# LanguageModelV2. Auth uses whatever the local `claude` binary is logged
# in with (OAuth via `claude /login`, or ANTHROPIC_API_KEY in env).
# Override only if `claude` is not on PATH.
AUTOFN_CLAUDE_BIN=claude

# Where JSONL traces are appended. One file per UTC day.
AUTOFN_TRACES_DIR=./traces

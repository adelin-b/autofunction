# OpenClaw gateway exposes an OpenAI-compatible endpoint that proxies to `claude -p`.
# Token lives in ~/.openclaw/openclaw.json under gateway.auth.token.
AUTOFN_BASE_URL=http://127.0.0.1:18789/v1
AUTOFN_API_KEY=replace-with-openclaw-gateway-token

# Default models. Sonnet is the "smart" tier, Haiku the "cheap" tier.
AUTOFN_MODEL_SMART=claude-sonnet-4-6
AUTOFN_MODEL_CHEAP=claude-haiku-4-5

# Where JSONL traces are appended. One file per day.
AUTOFN_TRACES_DIR=./traces

# autofunction spawns the Claude Code CLI (`claude -p`) as a subprocess.
# Authentication uses whatever `claude` itself is logged in with (OAuth via
# `claude /login`, or ANTHROPIC_API_KEY in your shell env for `--bare` mode).
#
# Override the binary path if `claude` is not on PATH.
AUTOFN_CLAUDE_BIN=claude

# Models. Sonnet = "smart" tier, Haiku = "cheap" tier (default).
AUTOFN_MODEL_SMART=claude-sonnet-4-6
AUTOFN_MODEL_CHEAP=claude-haiku-4-5

# Where JSONL traces are appended. One file per day.
AUTOFN_TRACES_DIR=./traces

{
  "name": "autofunction",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Typed AI-powered functions with sandbox, observability, multi-model eval, and code-shadow autoresearch loop",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "example:detect-theme": "tsx examples/detectTheme.ts",
    "traces:query": "tsx src/cli/traces.ts"
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.3-r.1",
    "dotenv": "^17.0.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.22.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  }
}

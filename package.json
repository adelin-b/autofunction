{
  "name": "autofunction",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Typed AI-powered functions with sandbox, observability, multi-model eval, and code-shadow autoresearch loop",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "example:detect-theme": "tsx examples/detectTheme.ts",
    "traces:query": "tsx src/cli/traces.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.0",
    "ai": "^5.0.0",
    "@duckdb/node-api": "^1.2.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
